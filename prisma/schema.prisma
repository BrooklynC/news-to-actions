// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActionStatus {
  OPEN
  DONE
  DISMISSED
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActionEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNED
  PRIORITY_CHANGED
}

enum ActionRecipeType {
  DEFAULT
  FOLLOW_UP
  RESEARCH
  OUTREACH
}

enum JobType {
  INGEST_TOPIC
  SUMMARIZE_ARTICLE
  GENERATE_ACTIONS_FOR_ARTICLE
  NOTIFY
  RETENTION_ENFORCER
  RUN_RECIPE
  EXPORT_ORG_DATA
}

enum JobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  DEAD
}

enum RunStatus {
  SUCCEEDED
  FAILED
}

enum CronRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum IngestionCadence {
  HOURLY
  DAILY
  WEEKLY
}

enum TopicCadence {
  HOURLY
  DAILY
  MANUAL
}

enum RecipeType {
  EXEC_BRIEF
  MARKETING_ANGLES
  COMPLIANCE_FLAGS
  SALES_PROSPECTING
  PRODUCT_SIGNALS
}

enum TopicFocus {
  ANY
  EXACT
  ENTITY
  PERSON
}

enum DigestCadence {
  OFF
  DAILY
  WEEKLY
}

enum NotificationType {
  ACTION_ASSIGNED
}

enum NotificationEntityType {
  ACTION_ITEM
}

enum NotificationDeliveryStatus {
  SENT
  FAILED
}

model Organization {
  id                            String                @id @default(cuid())
  clerkOrgId                    String                @unique
  name                          String
  ingestCadence                 TopicCadence          @default(DAILY)
  actionItemsPerPersonaPerArticle Int                  @default(2)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  memberships          Membership[]
  topics               Topic[]
  personas             Persona[]
  orgSelectedPersonas  OrgSelectedPersona[]
  articles             Article[]
  actionItems          ActionItem[]
  backgroundJobs       BackgroundJob[]
  notificationSettings NotificationSettings?
  notifications        Notification[]
}

model NotificationSettings {
  id              String        @id @default(cuid())
  organizationId  String        @unique
  slackWebhookUrl String?
  slackChannel    String?
  emailRecipients String?
  digestCadence   DigestCadence @default(OFF)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String                     @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  entityType     NotificationEntityType
  entityId       String
  title          String
  body           String?
  readAt         DateTime?
  deliveryStatus NotificationDeliveryStatus @default(SENT)
  deliveredAt    DateTime                   @default(now())
  lastError      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, entityType, entityId, type], name: "notification_dedupe_key")
  @@index([organizationId, userId, readAt])
  @@index([organizationId, createdAt])
}

model User {
  id                  String            @id @default(cuid())
  clerkUserId         String            @unique
  email               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  memberships         Membership[]
  assignedActionItems ActionItem[]      @relation("ActionItemAssignee")
  actionItemAudits    ActionItemAudit[]
  notifications       Notification[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Topic {
  id                 String           @id @default(cuid())
  organizationId     String
  name               String
  query              String
  searchPhrase       String?
  focusFilter        TopicFocus       @default(ANY)
  displayName        String?
  ingestionCadence   IngestionCadence @default(DAILY)
  isIngestionEnabled Boolean          @default(true)
  nextIngestAt       DateTime?
  lastIngestAt       DateTime?
  ingestEveryMinutes Int?
  cadence            TopicCadence     @default(HOURLY)
  nextRunAt          DateTime?
  recipeType         RecipeType       @default(EXEC_BRIEF)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organization       Organization     @relation(fields: [organizationId], references: [id])
  articles           Article[]
  actionItems        ActionItem[]
  topicPersonas      TopicPersona[]

  @@unique([organizationId, name])
  @@index([organizationId, isIngestionEnabled, nextIngestAt])
  @@index([organizationId, cadence, nextRunAt])
}

model TopicPersona {
  topicId   String
  personaId String
  createdAt DateTime @default(now())

  topic   Topic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  persona Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@id([topicId, personaId])
  @@index([topicId])
  @@index([personaId])
}

model OrgSelectedPersona {
  organizationId String
  personaId      String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  persona      Persona       @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@id([organizationId, personaId])
  @@index([organizationId])
  @@index([personaId])
}

model Persona {
  id                  String               @id @default(cuid())
  organizationId      String
  name                String
  recipeType          RecipeType?          @default(EXEC_BRIEF)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id])
  actionItems         ActionItem[]
  topicPersonas       TopicPersona[]
  orgSelectedPersonas OrgSelectedPersona[]

  @@unique([organizationId, name])
}

model Article {
  id             String       @id @default(cuid())
  organizationId String
  topicId        String
  url            String
  title          String
  source         String?
  publishedAt    DateTime?
  rssSnippet     String?      // Raw snippet from RSS; used by summarization before AI runs
  summary        String?      // AI-generated 3–5 bullet summary
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  topic          Topic        @relation(fields: [topicId], references: [id])
  actionItems    ActionItem[]

  @@unique([organizationId, url])
  @@index([organizationId, topicId])
  @@index([publishedAt])
}

model ActionItem {
  id              String            @id @default(cuid())
  organizationId  String
  articleId       String?
  topicId         String?
  title           String? // display title; backfilled from text if null
  description     String?
  text            String // legacy: title:description
  normalizedTitle String
  status          ActionStatus      @default(OPEN)
  priority        String? // legacy; use priorityLevel when set
  priorityLevel   ActionPriority?   @default(MEDIUM)
  personaId       String?
  assigneeUserId  String?
  dueDate         String?
  confidenceScore Float?
  recipeType      ActionRecipeType?
  createdByAI     Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id])
  article         Article?          @relation(fields: [articleId], references: [id])
  topic           Topic?            @relation(fields: [topicId], references: [id])
  persona         Persona?          @relation(fields: [personaId], references: [id])
  assigneeUser    User?             @relation("ActionItemAssignee", fields: [assigneeUserId], references: [id])
  audits          ActionItemAudit[]
  events          ActionEvent[]

  @@unique([organizationId, articleId, normalizedTitle])
  @@index([organizationId])
  @@index([articleId])
  @@index([topicId])
  @@index([organizationId, status])
  @@index([organizationId, priorityLevel])
  @@index([organizationId, updatedAt])
  @@index([organizationId, articleId])
}

model ActionEvent {
  id             String          @id @default(cuid())
  organizationId String
  actionId       String
  eventType      ActionEventType
  actorUserId    String?
  metadata       Json // small deltas only; { delta?, source }
  createdAt      DateTime        @default(now())

  action ActionItem @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([organizationId, actionId, createdAt])
  @@index([organizationId, createdAt])
}

model ActionItemAudit {
  id           String   @id @default(cuid())
  actionItemId String
  actorUserId  String?
  field        String
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())

  actionItem ActionItem @relation(fields: [actionItemId], references: [id], onDelete: Cascade)
  actorUser  User?      @relation(fields: [actorUserId], references: [id])

  @@index([actionItemId, createdAt])
}

model UsageEvent {
  id             String      @id @default(cuid())
  organizationId String
  userId         String? // optional, useful later even if org-scoped now
  action         UsageAction
  createdAt      DateTime    @default(now())
  // Token usage (filled after OpenAI call when available)
  inputTokens    Int?
  outputTokens   Int?
  model          String?

  @@index([organizationId, createdAt])
  @@index([organizationId, action, createdAt])
}

enum UsageAction {
  SUMMARIZE
  GENERATE_ACTIONS
}

model BackgroundJob {
  id             String    @id @default(cuid())
  organizationId String
  type           JobType
  status         JobStatus @default(QUEUED)
  payloadJson    String
  idempotencyKey String
  runAt          DateTime  @default(now())
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  lockedAt       DateTime?
  lockedBy       String?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         BackgroundJobRun[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId])
  @@index([organizationId, status, runAt])
  @@index([status])
}

model BackgroundJobRun {
  id              String    @id @default(cuid())
  organizationId  String
  backgroundJobId String?
  jobType         JobType
  status          RunStatus
  attemptNumber   Int
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  durationMs      Int?
  errorMessage    String?
  createdAt       DateTime  @default(now())

  backgroundJob BackgroundJob? @relation(fields: [backgroundJobId], references: [id], onDelete: SetNull)

  @@index([organizationId, startedAt])
  @@index([organizationId, status, startedAt])
  @@index([backgroundJobId, startedAt])
}

model JobRun {
  id             String   @id @default(cuid())
  organizationId String
  jobId          String
  type           JobType
  attempt        Int
  status         String
  startedAt      DateTime
  finishedAt     DateTime
  durationMs     Int
  queueWaitMs    Int
  errorMessage   String?
  createdAt      DateTime @default(now())

  @@index([organizationId, startedAt])
  @@index([organizationId, type, startedAt])
  @@index([jobId, attempt])
}

model CronLock {
  id        String   @id @default(cuid())
  key       String   @unique
  owner     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model CronRun {
  id         String        @id @default(cuid())
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  status     CronRunStatus @default(RUNNING)
  error      String?
  requestId  String?       @unique
  createdAt  DateTime      @default(now())

  @@index([startedAt])
  @@index([status, startedAt])
}
